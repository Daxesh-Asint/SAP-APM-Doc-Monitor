flowchart TD
    A["⏰ Cloud Scheduler\nTriggers at Defined Time\n(e.g. 10 AM & 6 PM IST)"]
    A --> B["🌐 Cloud Run App Wakes Up\n(Receives HTTP Request)"]
    B --> C["📥 Load Previous Snapshots\n(From Cloud Storage)"]
    C --> D["🔍 Discover All Doc Pages\n(Reads SAP Help Portal TOC)"]
    D --> E["📄 Fetch Each Page\n(Using Headless Browser)"]
    E --> F["📝 Extract Clean Text\n(Remove HTML / UI Noise)"]
    F --> G{"🔎 Compare with\nPrevious Snapshot"}
    G -->|"Changes Found"| H["📊 Classify Changes\n(High / Medium / Low Severity)"]
    G -->|"No Changes"| I["✅ Page Unchanged"]
    H --> J["💾 Save Updated Snapshot\n(To Cloud Storage)"]
    I --> K{"More Pages?"}
    J --> K
    K -->|"Yes"| E
    K -->|"No"| L{"Any Changes\nDetected?"}
    L -->|"Yes"| M["📧 Send Email Report\n(With Change Details)"]
    L -->|"No"| N["📧 Send 'No Changes' Email\n(Confirmation Report)"]
    M --> O["✅ Done — Waiting for\nNext Scheduled Run"]
    N --> O

    style A fill:#4A90D9,stroke:#2C5F8A,color:#fff
    style B fill:#5BA85B,stroke:#3D7A3D,color:#fff
